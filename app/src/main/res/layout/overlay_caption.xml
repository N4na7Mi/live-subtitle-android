<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/overlayRoot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/overlay_card_bg"
        android:elevation="12dp"
        android:minWidth="320dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:id="@+id/overlayHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/overlayStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_dot" />

            <TextView
                android:id="@+id/overlayStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/status_idle"
                android:textColor="#B4FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/overlayLangBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/lang_badge_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/lang_badge_prefix"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/overlayLockBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="44dp"
                android:paddingHorizontal="8dp"
                android:text="@string/lock"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />

            <Button
                android:id="@+id/overlayMinimizeBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="48dp"
                android:paddingHorizontal="8dp"
                android:text="@string/minimize"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/overlayOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="8"
            android:text="@string/caption_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/overlayDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#1AFFFFFF" />

        <TextView
            android:id="@+id/overlayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="6"
            android:text=""
            android:textColor="#B4FFFFFF"
            android:textSize="12sp"
            android:textStyle="italic" />

        <LinearLayout
            android:id="@+id/overlayControlsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlayToggleBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/overlay_btn_primary"
                android:minWidth="64dp"
                android:paddingHorizontal="12dp"
                android:text="@string/start"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/overlayClearBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="64dp"
                android:paddingHorizontal="12dp"
                android:text="@string/clear"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/overlayCloseBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="64dp"
                android:paddingHorizontal="12dp"
                android:text="@string/close"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/overlaySettingsBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/overlay_btn_secondary"
                android:contentDescription="@string/open_settings"
                android:src="@android:drawable/ic_menu_preferences"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
