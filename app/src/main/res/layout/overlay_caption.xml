<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <TextView
        android:id="@+id/overlayBall"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/overlay_ball_bg"
        android:gravity="center"
        android:text="@string/overlay_ball_text"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/overlayRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/overlay_card_bg"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:id="@+id/overlayHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/overlayStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_dot" />

            <TextView
                android:id="@+id/overlayStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/status_idle"
                android:textColor="#B4FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/overlayLangBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/lang_badge_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/lang_badge_prefix"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/overlayLockBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="44dp"
                android:paddingHorizontal="8dp"
                android:text="@string/lock"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />

            <Button
                android:id="@+id/overlayMinimizeBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="48dp"
                android:paddingHorizontal="8dp"
                android:text="@string/minimize"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/overlayOutput"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:gravity="center_vertical"
            android:maxLines="2"
            android:text="@string/caption_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/overlayDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#1AFFFFFF"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlayInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="6"
            android:text=""
            android:textColor="#B4FFFFFF"
            android:textSize="12sp"
            android:textStyle="italic"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/overlayControlsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlayToggleBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/overlay_btn_primary"
                android:minWidth="56dp"
                android:paddingHorizontal="10dp"
                android:text="@string/start"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/overlayRestartBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="52dp"
                android:paddingHorizontal="10dp"
                android:text="@string/restart_session"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/overlayLogBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="52dp"
                android:paddingHorizontal="10dp"
                android:text="@string/session_log"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/overlaySettingsBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/overlay_btn_secondary"
                android:contentDescription="@string/open_settings"
                android:src="@android:drawable/ic_menu_preferences"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/overlayToolsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlayFontMinusBtn"
                android:layout_width="36dp"
                android:layout_height="30dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="0dp"
                android:paddingHorizontal="0dp"
                android:text="@string/font_smaller"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/overlayFontPlusBtn"
                android:layout_width="36dp"
                android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="0dp"
                android:paddingHorizontal="0dp"
                android:text="@string/font_larger"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/overlaySourceBtn"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="56dp"
                android:paddingHorizontal="8dp"
                android:text="@string/source_mic_short"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Button
                android:id="@+id/overlayCloseBtn"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="48dp"
                android:paddingHorizontal="8dp"
                android:text="@string/close"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/overlayResizeHandle"
                android:layout_width="34dp"
                android:layout_height="30dp"
                android:background="@drawable/overlay_btn_secondary"
                android:gravity="center"
                android:text="@string/resize_handle"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
